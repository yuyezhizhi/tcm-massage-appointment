.rating-component {
  padding: 20rpx 0;
}

.rating-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.rating-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
}

.rating-required {
  color: #ff4444;
  font-size: 28rpx;
  margin-left: 8rpx;
}

.stars {
  display: flex;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.star {
  font-size: 48rpx;
  color: #e0e0e0;
  transition: all 0.2s;
}

.star.active {
  color: #ffd700;
}

.star:active {
  transform: scale(1.2);
}

.rating-input {
  width: 100%;
  min-height: 150rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 1rpx solid #e5e5e5;
}

.rating-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 10rpx;
}

.char-count {
  font-size: 24rpx;
  color: #999999;
}
