.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  background: #ffffff;
  padding: 30rpx;
  display: flex;
  justify-content: flex-end;
  border-bottom: 1rpx solid #e5e5e5;
}

.add-button {
  background: linear-gradient(135deg, #4A90A4 0%, #67B8C9 100%);
  color: #ffffff;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 30rpx;
  border: none;
}

.services-list {
  padding: 30rpx;
}

.service-item {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.service-image {
  width: 200rpx;
  height: 200rpx;
  background: #e0e0e0;
  flex-shrink: 0;
}

.service-content {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.service-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.service-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.service-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #4A90A4;
  padding: 8rpx 16rpx;
  background: #f0f8ff;
  border-radius: 8rpx;
}

.action-btn.delete {
  color: #ff4444;
  background: #fff0f0;
}

.service-description {
  font-size: 26rpx;
  color: #666666;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.service-meta {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.service-price {
  font-size: 30rpx;
  color: #ff4444;
  font-weight: bold;
}

.service-duration,
.service-category {
  font-size: 24rpx;
  color: #999999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.service-status {
  margin-top: 12rpx;
}

.status-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.status-active {
  background: #e8f5e9;
  color: #4caf50;
}

.status-inactive {
  background: #f5f5f5;
  color: #999999;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  color: #999999;
  font-size: 28rpx;
  display: block;
  margin-bottom: 40rpx;
}

.add-first-service {
  background: linear-gradient(135deg, #4A90A4 0%, #67B8C9 100%);
  color: #ffffff;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  border: none;
  display: inline-block;
}
