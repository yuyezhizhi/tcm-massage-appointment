.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.filter-section {
  background: #ffffff;
  padding: 30rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.filter-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.filter-picker {
  flex: 1;
}

.date-picker {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  text-align: center;
}

.date-picker text {
  font-size: 28rpx;
  color: #333333;
}

.filter-separator {
  padding: 0 30rpx;
  color: #999999;
  font-size: 28rpx;
}

.status-tabs {
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666666;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.tab-item.active {
  background: #4A90A4;
  color: #ffffff;
}

.orders-list {
  padding: 30rpx;
}

.order-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 24rpx;
  color: #999999;
}

.order-status {
  font-size: 28rpx;
  font-weight: bold;
}

.status-pending {
  color: #ff9900;
}

.status-confirmed {
  color: #4A90A4;
}

.status-completed {
  color: #4caf50;
}

.status-cancelled {
  color: #999999;
}

.order-body {
  margin-bottom: 20rpx;
}

.order-row {
  display: flex;
  margin-bottom: 12rpx;
}

.order-label {
  font-size: 26rpx;
  color: #666666;
  min-width: 140rpx;
}

.order-value {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
}

.order-value.amount {
  font-size: 30rpx;
  color: #ff4444;
  font-weight: bold;
  text-align: right;
}

.order-actions {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.confirm-button,
.complete-button,
.cancel-button {
  flex: 1;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 12rpx;
  border: none;
}

.confirm-button {
  background: linear-gradient(135deg, #4A90A4 0%, #67B8C9 100%);
  color: #ffffff;
}

.complete-button {
  background: linear-gradient(135deg, #4caf50 0%, #66bb6a 100%);
  color: #ffffff;
}

.cancel-button {
  background: #ffffff;
  color: #ff4444;
  border: 1rpx solid #ff4444;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  color: #999999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 28rpx;
}
