.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  background: #ffffff;
  padding: 30rpx;
  display: flex;
  justify-content: flex-end;
  border-bottom: 1rpx solid #e5e5e5;
}

.date-range-picker {
  padding: 16rpx 30rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
}

.picker-display {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.picker-display text {
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
}

.services-stats,
.revenue-stats {
  background: #ffffff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 30rpx;
}

.services-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.service-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.service-rank {
  margin-right: 20rpx;
}

.rank-num {
  display: inline-block;
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  background: #cccccc;
  border-radius: 50%;
}

.rank-1 {
  background: #ffd700;
}

.rank-2 {
  background: #c0c0c0;
}

.rank-3 {
  background: #cd7f32;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.service-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.service-count {
  font-size: 26rpx;
  color: #999999;
  margin-top: 4rpx;
}

.service-revenue {
  text-align: right;
}

.revenue-value {
  font-size: 30rpx;
  color: #ff4444;
  font-weight: bold;
}

.revenue-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.revenue-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.revenue-item:last-child {
  border-bottom: none;
}

.revenue-date {
  font-size: 28rpx;
  color: #333333;
}

.revenue-amount {
  font-size: 30rpx;
  color: #ff4444;
  font-weight: bold;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  color: #999999;
  font-size: 28rpx;
}
