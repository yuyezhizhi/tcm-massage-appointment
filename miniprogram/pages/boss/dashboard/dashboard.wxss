.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #4A90A4 0%, #67B8C9 100%);
  padding: 40rpx 30rpx 100rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 20rpx;
}

.date-range-picker {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  color: #ffffff;
  font-size: 28rpx;
}

.picker-arrow {
  margin-left: 10rpx;
  font-size: 20rpx;
}

.stats-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 30rpx;
  margin-top: -60rpx;
}

.stat-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.stat-card.primary {
  background: linear-gradient(135deg, #4A90A4 0%, #67B8C9 100%);
  color: #ffffff;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 10rpx;
}

.stat-card.primary .stat-label {
  color: rgba(255, 255, 255, 0.8);
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
}

.stat-card.primary .stat-value {
  color: #ffffff;
}

.stat-unit {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.stat-card.primary .stat-unit {
  color: rgba(255, 255, 255, 0.8);
}

.order-status-section {
  background: #ffffff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 30rpx;
}

.status-grid {
  display: flex;
  justify-content: space-around;
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-count {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.status-pending {
  color: #ff9900;
}

.status-confirmed {
  color: #4A90A4;
}

.status-completed {
  color: #4caf50;
}

.status-cancelled {
  color: #999999;
}

.status-label {
  font-size: 26rpx;
  color: #666666;
}

.chart-section {
  background: #ffffff;
  margin: 0 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.chart-container {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 300rpx;
  padding: 20rpx 0;
}

.chart-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-wrapper {
  width: 40rpx;
  height: 200rpx;
  background: #f0f0f0;
  border-radius: 8rpx 8rpx 0 0;
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.bar {
  width: 100%;
  background: linear-gradient(180deg, #4A90A4 0%, #67B8C9 100%);
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.3s;
}

.bar-date {
  font-size: 22rpx;
  color: #999999;
  margin-top: 10rpx;
}

.bar-value {
  font-size: 20rpx;
  color: #666666;
  margin-top: 4rpx;
}

.quick-actions {
  background: #ffffff;
  margin: 0 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.action-icon {
  font-size: 50rpx;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 24rpx;
  color: #333333;
}
