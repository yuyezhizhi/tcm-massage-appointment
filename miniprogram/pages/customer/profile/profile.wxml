<view class="container">
  <view class="user-section">
    <view class="user-info">
      <image class="user-avatar" src="{{userInfo?.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-details">
        <text class="user-nickname">{{userInfo?.nickname || '点击登录'}}</text>
        <text class="user-phone" wx:if="{{userInfo?.phone}}">{{userInfo.phone}}</text>
      </view>
    </view>
  </view>

  <view class="member-card" wx:if="{{memberInfo}}">
    <view class="member-header">
      <text class="member-level">{{getMemberLevelText(memberInfo.level)}}</text>
      <text class="member-discount">享{{memberInfo.discount * 10}}折优惠</text>
    </view>
    <view class="member-stats">
      <view class="stat-item">
        <text class="stat-value">{{memberInfo.points}}</text>
        <text class="stat-label">积分</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">¥{{(memberInfo.totalConsumption / 100).toFixed(0)}}</text>
        <text class="stat-label">累计消费</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{memberInfo.nextLevel ? getMemberLevelText(memberInfo.nextLevel) : '-'}}</text>
        <text class="stat-label">下一等级</text>
      </view>
    </view>
    <view class="progress-bar" wx:if="{{memberInfo.nextLevelPoints}}">
      <view class="progress-fill" style="width: {{getProgressPercent(memberInfo.totalConsumption, memberInfo.nextLevelPoints)}}%"></view>
    </view>
    <text class="progress-text">还差 ¥{{((memberInfo.nextLevelPoints - memberInfo.totalConsumption) / 100).toFixed(0)}} 升级</text>
  </view>

  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="goToOrders">
        <text class="menu-icon">📝</text>
        <text class="menu-text">我的订单</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToPointsHistory">
        <text class="menu-icon">💰</text>
        <text class="menu-text">积分明细</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="goToReviews">
        <text class="menu-icon">⭐</text>
        <text class="menu-text">我的评价</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="copyToCustomerService">
        <text class="menu-icon">📞</text>
        <text class="menu-text">联系客服</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-group" wx:if="{{userInfo?.role === 'boss'}}">
      <view class="menu-item boss-entry" bindtap="goToBossDashboard">
        <text class="menu-icon">👑</text>
        <text class="menu-text">管理后台</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <view class="logout-section" wx:if="{{userInfo}}">
    <button class="logout-button" bindtap="logout">退出登录</button>
  </view>
</view>
