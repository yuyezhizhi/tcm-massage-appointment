.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.user-section {
  background: linear-gradient(135deg, #4A90A4 0%, #67B8C9 100%);
  padding: 60rpx 30rpx 100rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #ffffff;
}

.user-details {
  display: flex;
  flex-direction: column;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.user-phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 10rpx;
}

.member-card {
  background: linear-gradient(135deg, #ff9900 0%, #ffb733 100%);
  margin: -60rpx 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  color: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.member-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.member-level {
  font-size: 36rpx;
  font-weight: bold;
}

.member-discount {
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.member-stats {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
}

.stat-label {
  font-size: 24rpx;
  margin-top: 8rpx;
  opacity: 0.8;
}

.stat-divider {
  width: 1rpx;
  background: rgba(255, 255, 255, 0.3);
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
  margin-top: 20rpx;
}

.progress-fill {
  height: 100%;
  background: #ffffff;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  margin-top: 16rpx;
  opacity: 0.8;
}

.menu-section {
  padding: 0 30rpx;
}

.menu-group {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #cccccc;
}

.boss-entry {
  background: linear-gradient(135deg, #fff5e6 0%, #ffffff 100%);
}

.logout-section {
  padding: 30rpx;
}

.logout-button {
  background: #ffffff;
  color: #ff4444;
  font-size: 30rpx;
  padding: 24rpx 0;
  border-radius: 16rpx;
  border: 1rpx solid #ff4444;
}
