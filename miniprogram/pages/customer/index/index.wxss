.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

.header {
  background: linear-gradient(135deg, #4A90A4 0%, #67B8C9 100%);
  padding: 40rpx 30rpx 60rpx;
  position: relative;
}

.greeting {
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
  display: block;
}

.shop-name {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-top: 10rpx;
}

.user-info {
  position: absolute;
  top: 40rpx;
  right: 30rpx;
}

.nickname {
  color: #ffffff;
  font-size: 24rpx;
}

.banner {
  margin: -40rpx 30rpx 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.banner-swiper {
  height: 300rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  background: #ffffff;
  margin: 0 30rpx 30rpx;
  padding: 40rpx 0;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.action-text {
  font-size: 26rpx;
  color: #333333;
}

.services-section {
  background: #ffffff;
  margin: 0 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  font-size: 24rpx;
  color: #999999;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.service-card {
  background: #f8f8f8;
  border-radius: 12rpx;
  overflow: hidden;
  transition: transform 0.2s;
}

.service-card:active {
  transform: scale(0.98);
}

.service-image {
  width: 100%;
  height: 200rpx;
  background: #e0e0e0;
}

.service-info {
  padding: 20rpx;
}

.service-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.service-duration {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.service-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.service-price {
  font-size: 30rpx;
  color: #ff4444;
  font-weight: bold;
}

.service-book {
  background: #4A90A4;
  color: #ffffff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  color: #999999;
  font-size: 28rpx;
}

.bottom-safe-area {
  height: env(safe-area-inset-bottom);
}
