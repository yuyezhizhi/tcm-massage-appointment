.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.filter-section {
  background: #ffffff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  padding: 0 30rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 30rpx;
  margin-right: 20rpx;
  font-size: 28rpx;
  color: #666666;
  background: #f5f5f5;
  border-radius: 30rpx;
  transition: all 0.3s;
}

.category-item.active {
  background: #4A90A4;
  color: #ffffff;
}

.services-list {
  padding: 30rpx;
}

.service-item {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.service-item:active {
  transform: scale(0.98);
}

.service-image {
  width: 240rpx;
  height: 240rpx;
  background: #e0e0e0;
  flex-shrink: 0;
}

.service-content {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.service-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.service-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.service-duration {
  font-size: 24rpx;
  color: #999999;
}

.service-description {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.service-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.price-section {
  display: flex;
  align-items: baseline;
}

.service-price {
  font-size: 36rpx;
  color: #ff4444;
  font-weight: bold;
}

.original-price {
  font-size: 26rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.book-button {
  background: linear-gradient(135deg, #4A90A4 0%, #67B8C9 100%);
  color: #ffffff;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 30rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  color: #999999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 28rpx;
}
