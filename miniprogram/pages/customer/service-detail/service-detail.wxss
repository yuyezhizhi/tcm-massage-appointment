.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.service-header {
  background: #ffffff;
  position: relative;
}

.header-image {
  width: 100%;
  height: 400rpx;
  background: #e0e0e0;
}

.service-basic-info {
  padding: 30rpx;
  position: relative;
}

.service-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 20rpx;
}

.service-meta {
  display: flex;
  gap: 30rpx;
  margin-bottom: 20rpx;
}

.service-duration,
.service-category {
  font-size: 26rpx;
  color: #999999;
  background: #f5f5f5;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
}

.service-price {
  font-size: 44rpx;
  color: #ff4444;
  font-weight: bold;
}

.monthly-sales {
  font-size: 24rpx;
  color: #999999;
}

.service-description {
  background: #ffffff;
  padding: 30rpx;
  margin-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 20rpx;
}

.description-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

.appointment-section {
  background: #ffffff;
  padding: 30rpx;
  margin-top: 20rpx;
}

.date-scroll {
  margin-bottom: 30rpx;
}

.date-list {
  white-space: nowrap;
}

.date-item {
  display: inline-block;
  width: 100rpx;
  text-align: center;
  padding: 20rpx 0;
  margin-right: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.date-item.active {
  background: #4A90A4;
  color: #ffffff;
}

.date-text {
  display: block;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.date-week {
  display: block;
  font-size: 24rpx;
}

.time-slots {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.time-slot {
  width: 160rpx;
  text-align: center;
  padding: 20rpx 0;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333333;
  position: relative;
}

.time-slot.selected {
  background: #4A90A4;
  color: #ffffff;
}

.time-slot.disabled {
  background: #e0e0e0;
  color: #cccccc;
}

.slot-status {
  display: block;
  font-size: 20rpx;
  margin-top: 4rpx;
}

.no-slots {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.remark-section {
  background: #ffffff;
  padding: 30rpx;
  margin-top: 20rpx;
}

.remark-input {
  width: 100%;
  min-height: 150rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.price-info {
  display: flex;
  flex-direction: column;
}

.total-price {
  font-size: 40rpx;
  color: #ff4444;
  font-weight: bold;
}

.member-discount {
  font-size: 24rpx;
  color: #ff9900;
  margin-top: 4rpx;
}

.book-button {
  background: linear-gradient(135deg, #4A90A4 0%, #67B8C9 100%);
  color: #ffffff;
  font-size: 32rpx;
  padding: 20rpx 60rpx;
  border-radius: 40rpx;
  border: none;
}

.book-button[disabled] {
  background: #cccccc;
}
