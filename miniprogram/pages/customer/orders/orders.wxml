<view class="container">
  <view class="filter-tabs">
    <view 
      class="tab-item {{currentTab === 'all' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="all"
    >
      全部
    </view>
    <view 
      class="tab-item {{currentTab === 'pending' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="pending"
    >
      待确认
    </view>
    <view 
      class="tab-item {{currentTab === 'confirmed' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="confirmed"
    >
      已确认
    </view>
    <view 
      class="tab-item {{currentTab === 'completed' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="completed"
    >
      已完成
    </view>
  </view>

  <view class="orders-list">
    <view 
      class="order-item"
      wx:for="{{orders}}"
      wx:key="orderNo"
      bindtap="goToDetail"
      data-order="{{item}}"
    >
      <view class="order-header">
        <text class="order-no">订单号：{{item.orderNo}}</text>
        <text class="order-status status-{{item.status}}">{{getStatusText(item.status)}}</text>
      </view>
      
      <view class="order-content">
        <view class="service-info">
          <text class="service-name">{{item.serviceName}}</text>
          <text class="appointment-time">{{formatDateTime(item.appointmentTime)}}</text>
        </view>
        <view class="order-footer">
          <text class="order-amount">¥{{item.finalAmount}}</text>
          <view class="order-actions" wx:if="{{item.status === 'pending'}}">
            <button class="cancel-button" bindtap="cancelOrder" data-id="{{item._id}}">取消</button>
          </view>
          <view class="order-actions" wx:if="{{item.status === 'completed' && !item.review}}">
            <button class="review-button" bindtap="submitReview" data-order="{{item}}">评价</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{orders.length === 0 && !loading}}">
    <text class="empty-text">暂无订单</text>
    <button class="go-book" bindtap="goToServices">去预约</button>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
